generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Modelo de datos

/*
* Tanto el id de los productos, direcciones, pagos y envíos se obtienen de las APIs 
* correspondientes por lo que no es necesario crear modelos adicionales para ellos.
*/
model Usuario{
  id String @id // Usamos el id de clerk
  direcciones Direccion[]
  carrito Carrito[]
  favoritos Favorito[]
  compras OrdenCompra[]
  createdAt DateTime @default(now())
}

model Favorito{
  id String @id @default(cuid())
  usuarioId String
  productoId String 

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  @@unique([usuarioId, productoId])
}

//TODO: Agregar createdAt 
model Carrito{
  id String @id @default(cuid())
  usuarioId String
  productoId String
  cantidad Int

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  @@unique([usuarioId, productoId])
}

/*
* Dejamos libre la direccion y telefono para que
* varios usuarios puedan compartir la misma dirección o teléfono si lo desean.
*/
model Direccion{
  id String @id @default(cuid())
  usuarioId String
  calle String
  numero String
  pisoDepto String? 
  localidad String
  provincia String
  codigoPostal String
  telefono String
  nombreDestinatario String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

model OrdenCompra{
  id String @id @default(cuid())
  usuarioId String
  pagoId String @unique
  envioId String @unique 
  estado String 
  total Int
  costoEnvio Int
  items ItemOrdenCompra[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

model ItemOrdenCompra{
  id String @id @default(cuid())
  ordenCompraId String
  productoId String 
  precio Int
  cantidad Int

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id])
}

